{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "..",
    "outDir": "dist-types",
    "paths": {
      "@/*": ["../packages/console-ui/src/*"],
      "@agent-moebius/console-ui": ["../packages/console-ui/src/index.ts"],
      "@agent-moebius/console-ui/globals.css": ["../packages/console-ui/src/styles/globals.css"]
    },
    "types": ["node", "electron"],
    "noEmit": true
  },
  "include": ["src", "tests", "scripts", "../src"]
}
